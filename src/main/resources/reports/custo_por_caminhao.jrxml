<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="Relatório - Custo por Caminhão" language="java"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="logoPath" class="java.lang.Object"/>
    <parameter name="codigoCaminhao" class="java.lang.String"/>
    <parameter name="placaCaminhao" class="java.lang.String"/>
    <parameter name="periodoInicio" class="java.time.LocalDate"/>
    <parameter name="periodoFim" class="java.time.LocalDate"/>
    <parameter name="totalCombustivel" class="java.math.BigDecimal"/>
    <parameter name="totalManutencao" class="java.math.BigDecimal"/>
    <parameter name="totalGeral" class="java.math.BigDecimal"/>

    <field name="data" class="java.time.LocalDate"/>
    <field name="tipo" class="java.lang.String"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="valor" class="java.math.BigDecimal"/>

    <title height="120">
        <element kind="image" x="10" y="4" width="120" height="50">
            <expression><![CDATA[$P{logoPath}]]></expression>
        </element>
        <element kind="staticText" x="140" y="6" width="520" height="20" fontSize="14" bold="true">
            <text><![CDATA[RELATÓRIO DE CUSTO POR CAMINHÃO]]></text>
        </element>
        <element kind="textField" x="140" y="30" width="520" height="16">
            <expression><![CDATA["Caminhão: " + $P{placaCaminhao} + " (" + $P{codigoCaminhao} + ")"]]></expression>
        </element>
        <element kind="textField" x="640" y="12" width="180" height="16" hTextAlign="Right">
            <expression><![CDATA["Período: " + $P{periodoInicio} + " até " + $P{periodoFim}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="0" y="64" width="258" height="22" forecolor="#FFFFFF" backcolor="#0F766E" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[COMBUSTÍVEL]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="0" y="86" width="258" height="22" pattern="'R$ ' #,##0.00" forecolor="#134E4A" backcolor="#CCFBF1" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA[$P{totalCombustivel}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="272" y="64" width="258" height="22" forecolor="#FFFFFF" backcolor="#1D4ED8" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[MANUTENÇÃO]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="272" y="86" width="258" height="22" pattern="'R$ ' #,##0.00" forecolor="#1E3A8A" backcolor="#DBEAFE" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA[$P{totalManutencao}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="544" y="64" width="258" height="22" forecolor="#FFFFFF" backcolor="#B45309" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[TOTAL GERAL]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="544" y="86" width="258" height="22" pattern="'R$ ' #,##0.00" forecolor="#7C2D12" backcolor="#FFEDD5" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA[$P{totalGeral}]]></expression>
        </element>
    </title>

    <columnHeader height="24">
        <element kind="staticText" mode="Opaque" x="0" y="3" width="90" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[DATA]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="90" y="3" width="140" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[ORIGEM]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="230" y="3" width="450" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[DESCRIÇÃO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="680" y="3" width="122" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[VALOR]]></text>
        </element>
    </columnHeader>

    <detail>
        <band height="18">
            <element kind="textField" x="0" y="1" width="90" height="15" hTextAlign="Center">
                <expression><![CDATA[$F{data}]]></expression>
            </element>
            <element kind="textField" x="90" y="1" width="140" height="15">
                <expression><![CDATA[$F{tipo}]]></expression>
            </element>
            <element kind="textField" x="230" y="1" width="450" height="15">
                <expression><![CDATA[$F{descricao}]]></expression>
            </element>
            <element kind="textField" x="680" y="1" width="122" height="15" pattern="'R$ ' #,##0.00" hTextAlign="Right">
                <expression><![CDATA[$F{valor}]]></expression>
            </element>
        </band>
    </detail>

    <pageFooter height="24">
        <element kind="textField" x="0" y="6" width="300" height="15">
            <expression><![CDATA["Emitido em: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></expression>
        </element>
        <element kind="textField" x="700" y="6" width="102" height="15" hTextAlign="Right">
            <expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>
</jasperReport>
