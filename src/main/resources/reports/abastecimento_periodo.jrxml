<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="Relatório - Abastecimento por Período" language="java"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="logoPath" class="java.lang.Object"/>

    <parameter name="periodoInicio" class="java.time.LocalDate"/>
    <parameter name="periodoFim" class="java.time.LocalDate"/>
    <parameter name="filtroCaminhao" class="java.lang.String"/>
    <parameter name="filtroMotorista" class="java.lang.String"/>

    <parameter name="totalLitros" class="java.math.BigDecimal"/>
    <parameter name="totalValor" class="java.math.BigDecimal"/>

    <field name="data" class="java.time.LocalDate"/>
    <field name="caminhao" class="java.lang.String"/>
    <field name="motorista" class="java.lang.String"/>
    <field name="posto" class="java.lang.String"/>
    <field name="cidade" class="java.lang.String"/>
    <field name="litros" class="java.math.BigDecimal"/>
    <field name="valorTotal" class="java.math.BigDecimal"/>
    <field name="kmOdometro" class="java.math.BigDecimal"/>
    <field name="mediaKmLitro" class="java.math.BigDecimal"/>
    <field name="tipoCombustivel" class="java.lang.String"/>

    <title height="118">
        <element kind="image" x="10" y="5" width="120" height="50">
            <expression><![CDATA[$P{logoPath}]]></expression>
        </element>

        <element kind="staticText" x="140" y="6" width="520" height="20" fontSize="14" bold="true">
            <text><![CDATA[RELATÓRIO DE ABASTECIMENTOS POR PERÍODO]]></text>
        </element>

        <element kind="textField" x="140" y="30" width="520" height="16">
            <expression><![CDATA["Caminhão: " + $P{filtroCaminhao} + " | Motorista: " + $P{filtroMotorista}]]></expression>
        </element>

        <element kind="textField" x="640" y="12" width="180" height="16" hTextAlign="Right">
            <expression><![CDATA["Período: " + $P{periodoInicio} + " até " + $P{periodoFim}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="0" y="64" width="394" height="22" forecolor="#FFFFFF" backcolor="#0F766E" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[TOTAL DE LITROS]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="0" y="86" width="394" height="22" pattern="#,##0.00" forecolor="#134E4A" backcolor="#CCFBF1" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA[$P{totalLitros}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="408" y="64" width="394" height="22" forecolor="#FFFFFF" backcolor="#1D4ED8" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[TOTAL FINANCEIRO]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="408" y="86" width="394" height="22" pattern="'R$ ' #,##0.00" forecolor="#1E3A8A" backcolor="#DBEAFE" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA[$P{totalValor}]]></expression>
        </element>
    </title>

    <columnHeader height="24">
        <element kind="staticText" mode="Opaque" x="0" y="3" width="70" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[DATA]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="70" y="3" width="110" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[CAMINHÃO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="180" y="3" width="150" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[MOTORISTA]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="330" y="3" width="105" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[POSTO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="435" y="3" width="95" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[CIDADE]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="530" y="3" width="60" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[KM]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="590" y="3" width="58" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[LITROS]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="648" y="3" width="82" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[VALOR]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="730" y="3" width="72" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[km/L]]></text>
        </element>
    </columnHeader>

    <detail>
        <band height="18">
            <element kind="textField" x="0" y="1" width="70" height="15">
                <expression><![CDATA[$F{data}]]></expression>
            </element>
            <element kind="textField" x="70" y="1" width="110" height="15">
                <expression><![CDATA[$F{caminhao}]]></expression>
            </element>
            <element kind="textField" x="180" y="1" width="150" height="15">
                <expression><![CDATA[$F{motorista}]]></expression>
            </element>
            <element kind="textField" x="330" y="1" width="105" height="15">
                <expression><![CDATA[$F{posto}]]></expression>
            </element>
            <element kind="textField" x="435" y="1" width="95" height="15">
                <expression><![CDATA[$F{cidade}]]></expression>
            </element>
            <element kind="textField" x="530" y="1" width="60" height="15" hTextAlign="Right">
                <expression><![CDATA[$F{kmOdometro}]]></expression>
            </element>
            <element kind="textField" x="590" y="1" width="58" height="15" pattern="#,##0.00" hTextAlign="Right">
                <expression><![CDATA[$F{litros}]]></expression>
            </element>
            <element kind="textField" x="648" y="1" width="82" height="15" pattern="'R$ ' #,##0.00" hTextAlign="Right">
                <expression><![CDATA[$F{valorTotal}]]></expression>
            </element>
            <element kind="textField" x="730" y="1" width="72" height="15" pattern="#,##0.00" hTextAlign="Right">
                <expression><![CDATA[$F{mediaKmLitro}]]></expression>
            </element>
        </band>
    </detail>

    <pageFooter height="24">
        <element kind="textField" x="0" y="6" width="300" height="15">
            <expression><![CDATA["Emitido em: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></expression>
        </element>
        <element kind="textField" x="700" y="6" width="102" height="15" hTextAlign="Right">
            <expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>

</jasperReport>
