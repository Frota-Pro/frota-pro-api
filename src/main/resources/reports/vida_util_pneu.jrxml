<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="Relatório - Vida Útil do Pneu" language="java"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="logoPath" class="java.lang.Object"/>

    <parameter name="filtroCaminhao" class="java.lang.String"/>
    <parameter name="totalPneus" class="java.lang.Long"/>


    <field name="codigoPneu" class="java.lang.String"/>
    <field name="numeroSerie" class="java.lang.String"/>
    <field name="marca" class="java.lang.String"/>
    <field name="modelo" class="java.lang.String"/>
    <field name="medida" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="caminhao" class="java.lang.String"/>
    <field name="kmTotal" class="java.math.BigDecimal"/>
    <field name="kmMeta" class="java.math.BigDecimal"/>
    <field name="percentualVida" class="java.math.BigDecimal"/>

    <title height="118">
        <element kind="image" x="10" y="5" width="120" height="50">
            <expression><![CDATA[$P{logoPath}]]></expression>
        </element>

        <element kind="staticText" x="140" y="6" width="520" height="20" fontSize="14" bold="true">
            <text><![CDATA[RELATÓRIO DE VIDA ÚTIL DOS PNEUS]]></text>
        </element>

        <element kind="textField" x="140" y="30" width="520" height="16">
            <expression><![CDATA["Filtro caminhão: " + $P{filtroCaminhao}]]></expression>
        </element>

        <element kind="textField" x="640" y="12" width="180" height="16" hTextAlign="Right">
            <expression><![CDATA["Total pneus: " + $P{totalPneus}]]></expression>
        </element>

        <element kind="staticText" mode="Opaque" x="0" y="64" width="802" height="22" forecolor="#FFFFFF" backcolor="#0F766E" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[ACOMPANHAMENTO DE VIDA ÚTIL E KM RODADO]]></text>
        </element>
        <element kind="textField" mode="Opaque" x="0" y="86" width="802" height="22" forecolor="#134E4A" backcolor="#CCFBF1" hTextAlign="Center" vTextAlign="Middle">
            <expression><![CDATA["Percentual de vida útil baseado na meta de km por pneu"]]></expression>
        </element>
    </title>

    <columnHeader height="24">
        <element kind="staticText" mode="Opaque" x="0" y="3" width="80" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[CÓDIGO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="80" y="3" width="110" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[SÉRIE]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="190" y="3" width="95" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[MARCA]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="285" y="3" width="120" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[MODELO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="405" y="3" width="105" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[MEDIDA]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="510" y="3" width="110" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[STATUS]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="620" y="3" width="95" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[CAMINHÃO]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="715" y="3" width="42" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[KM]]></text>
        </element>
        <element kind="staticText" mode="Opaque" x="757" y="3" width="45" height="18" forecolor="#FFFFFF" backcolor="#334155" bold="true" hTextAlign="Center">
            <text><![CDATA[% VIDA]]></text>
        </element>
    </columnHeader>

    <detail>
        <band height="18">
            <element kind="textField" x="0" y="1" width="80" height="15">
                <expression><![CDATA[$F{codigoPneu}]]></expression>
            </element>
            <element kind="textField" x="80" y="1" width="110" height="15">
                <expression><![CDATA[$F{numeroSerie}]]></expression>
            </element>
            <element kind="textField" x="190" y="1" width="95" height="15">
                <expression><![CDATA[$F{marca}]]></expression>
            </element>
            <element kind="textField" x="285" y="1" width="120" height="15">
                <expression><![CDATA[$F{modelo}]]></expression>
            </element>
            <element kind="textField" x="405" y="1" width="105" height="15">
                <expression><![CDATA[$F{medida}]]></expression>
            </element>
            <element kind="textField" x="510" y="1" width="110" height="15" hTextAlign="Center">
                <expression><![CDATA[$F{status}]]></expression>
            </element>
            <element kind="textField" x="620" y="1" width="95" height="15">
                <expression><![CDATA[$F{caminhao}]]></expression>
            </element>
            <element kind="textField" x="715" y="1" width="42" height="15" pattern="#,##0" hTextAlign="Right">
                <expression><![CDATA[$F{kmTotal}]]></expression>
            </element>
            <element kind="textField" x="757" y="1" width="45" height="15" pattern="#,##0.00" hTextAlign="Right">
                <expression><![CDATA[$F{percentualVida}]]></expression>
            </element>
        </band>
    </detail>

    <pageFooter height="24">
        <element kind="textField" x="0" y="6" width="300" height="15">
            <expression><![CDATA["Emitido em: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></expression>
        </element>
        <element kind="textField" x="700" y="6" width="102" height="15" hTextAlign="Right">
            <expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>

</jasperReport>
